# Requisito del proyecto: PHP ^8.2 | Laravel 12.
APP_NAME="HelpDesk"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=helpdesk
DB_USERNAME=root
DB_PASSWORD=

# Para sesión única por usuario (un solo equipo/navegador a la vez), usar: SESSION_DRIVER=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
# En producción con HTTPS, usar true para enviar cookie solo por HTTPS:
SESSION_SECURE_COOKIE=false
# Opciones: lax, strict, none. Recomendado: lax
SESSION_SAME_SITE=lax

CACHE_DRIVER=file
QUEUE_CONNECTION=sync

# Disco por defecto (Laravel 9+). Si migras desde .env antiguo, FILESYSTEM_DRIVER sigue siendo leído como respaldo.
FILESYSTEM_DISK=local
# FILESYSTEM_DRIVER=local

# Hashing (Laravel 11/12 — ver config/hashing.php)
# HASH_DRIVER=bcrypt
# HASH_VERIFY=false recomendado si la BD tiene hashes Argon2 u otro algoritmo; true fuerza que coincida con HASH_DRIVER.
# HASH_REHASH_ON_LOGIN=true
# BCRYPT_ROUNDS=10
# BCRYPT_LIMIT=
# ARGON_MEMORY=1024
# ARGON_THREADS=2
# ARGON_TIME=2

# Retención authentication_logs (Fase 4; comando helpdesk:prune-authentication-logs)
# HELP_DESK_AUTH_LOG_RETENTION_DAYS=180

# Retención notificaciones de panel: leídas (read_at) y no leídas (created_at); helpdesk:prune-notifications semanal; mínimo 30 días en comando
# HELP_DESK_NOTIFICATIONS_RETENTION_DAYS=90

# Vigencia de contraseña (días desde el último cambio) y aviso previo (días antes del vencimiento; helpdesk:notify-password-expiry diario)
# HELP_PASSWORD_VALIDITY_DAYS=30
# HELP_PASSWORD_WARNING_DAYS=5

# --- SEGURIDAD (producción) ---
# APP_ENV=production
# APP_DEBUG=false
# SESSION_SECURE_COOKIE=true
# SESSION_ENCRYPT=true
# SESSION_SAME_SITE=lax
# LOG_CHANNEL=daily
# LOG_LEVEL=warning
